{
  "name": "lazarus-sentinel",
  "version": "0.1.0",
  "productName": "Lazarus Sentinel",
  "private": true,
  "description": "Desktop-first multi-server safety terminal.",
  "author": "Sumit Jadhav",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "npm run rebuild:electron && electron-vite dev",
    "build": "electron-vite build",
    "check": "node scripts/check.mjs",
    "icons": "python3 scripts/generate-icons.py",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3 -w node-pty",
    "rebuild:node": "npm rebuild better-sqlite3 node-pty",
    "pack": "npm run icons && npm run build && electron-builder --dir && npm rebuild better-sqlite3 node-pty",
    "dist": "npm run icons && npm run build && electron-builder && npm rebuild better-sqlite3 node-pty",
    "preview": "electron-vite preview",
    "test": "vitest run"
  },
  "build": {
    "appId": "io.lazarus.sentinel",
    "productName": "Lazarus Sentinel",
    "icon": "assets/build/icon",
    "directories": {
      "output": "release",
      "buildResources": "assets/build"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "assets/build/entitlements.mac.plist",
      "entitlementsInherit": "assets/build/entitlements.mac.plist"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "electron-store": "^10.1.0",
    "node-pty": "^1.0.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vitest": "^4.1.6",
    "xterm": "^5.3.0"
  }
}
