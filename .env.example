# Electron Builder code-signing and notarization placeholders.
# Keep real values out of git and local handoff archives.

# Apple Developer Team ID, for example ABCDE12345.
APPLE_TEAM_ID=

# Apple ID used for notarization.
APPLE_ID=

# App-specific password for the Apple ID above.
APPLE_APP_SPECIFIC_PASSWORD=

# Optional certificate identity or base64/p12 certificate path for electron-builder.
CSC_NAME=
CSC_LINK=
CSC_KEY_PASSWORD=
